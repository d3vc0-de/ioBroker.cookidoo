{
	"extends": "@tsconfig/node20/tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"allowJs": true,
		"checkJs": true,
		"resolveJsonModule": true,
		"noImplicitAny": false,
		"useUnknownInCatchVariables": false
	},
	"include": [
		"**/*.js",
		"**/*.d.ts"
	],
	"exclude": [
		"node_modules/**",
		"widgets/**"
	]
}
